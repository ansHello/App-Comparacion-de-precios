    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ComparacionPrecios.Views">

    <!-- LOGIN -->
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:VLogin}"
        Route="VLogin" />

    <!-- HOME -->
