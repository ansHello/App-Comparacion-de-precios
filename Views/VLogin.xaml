<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ComparacionPrecios.Views.VLogin"
             Title="Iniciar Sesión"
             BackgroundColor="#2E237A">

    <ScrollView>
        <VerticalStackLayout Spacing="18"
                             Padding="30"
                             VerticalOptions="Center"
                             HorizontalOptions="Center">

            <!-- Logo/Icono -->
            <!-- Logo/Icono -->
            <!-- CONTENEDOR DEL LOGO -->
            <Frame WidthRequest="140"
               HeightRequest="140"
               CornerRadius="35"
               Padding="0"
               HasShadow="True"
               BackgroundColor="#4A3BB5"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               BorderColor="#5F52D9">

                <!-- Imagen -->
                <Image Source="smartshop.png"
                   Aspect="AspectFill"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill" />

            </Frame>

            <!-- Título -->
            <Label Text="SmartShop"
                   FontSize="38"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <!-- Subtítulo -->
            <Label Text="Encuentra la mejor opción de compra&#10;rápida y segura."
                   FontSize="17"
                   TextColor="#D6D1FF"
                   HorizontalTextAlignment="Center"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <!-- Contenedor principal -->
            <Frame BackgroundColor="#4C3FC4"
                   CornerRadius="25"
                   Padding="25"
                   HasShadow="False"
                   WidthRequest="320">

                <VerticalStackLayout Spacing="18">

                    <!-- Email -->
                    <Entry x:Name="txtEmail"
                           Placeholder="Correo Electrónico"
                           Keyboard="Email"
                           TextColor="White"
                           PlaceholderColor="#D0CFFF"
                           BackgroundColor="#5B4FD1"
                           HeightRequest="55"
                           Margin="0,5"
                           FontSize="16" />

                    <!-- Password -->
                    <Entry x:Name="txtPassword"
                           Placeholder="Contraseña"
                           IsPassword="True"
                           TextColor="White"
                           PlaceholderColor="#D0CFFF"
                           BackgroundColor="#5B4FD1"
                           HeightRequest="55"
                           Margin="0,5"
                           FontSize="16" />

                    <!-- Botón ingresar -->
                    <Button x:Name="btnIngresar"
                            Text="Iniciar sesión"
                            Clicked="btnIngresar_Clicked"
                            BackgroundColor="White"
                            TextColor="#4A3BB5"
                            CornerRadius="18"
                            FontAttributes="Bold"
                            FontSize="20"
                            HeightRequest="58" />

                    <!-- Botón registrar -->
                    <Button x:Name="btnRegistrar"
                            Text="Crear cuenta nueva"
                            Clicked="btnRegistrar_Clicked"
                            BackgroundColor="Transparent"
                            BorderColor="#B8B2FF"
                            BorderWidth="1.5"
                            TextColor="White"
                            CornerRadius="18"
                            FontAttributes="Bold"
                            FontSize="18"
                            HeightRequest="55"/>

                    <!-- Texto inferior -->
                    <Label Text="Al continuar aceptas nuestros&#10;Términos y Condiciones y Política de Privacidad."
                           FontSize="12"
                           TextColor="#D6D1FF"
                           HorizontalTextAlignment="Center"
                           Margin="0,10,0,0"/>
                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>